# =================================
# Loup-Garou — Lumières Philips Hue
# =================================
# Copie ce fichier en `.env` (ou exporte les variables avant `node server.js`)
# puis remplis avec tes vraies valeurs. Tant que LIGHTS_ENABLED!="true",
# le module est totalement dormant — aucun appel réseau, aucun warning.

LIGHTS_ENABLED=false

# IP locale de ton Bridge Hue (en Ethernet de préférence).
# La trouver via : https://discovery.meethue.com  ou dans l'app Hue → Paramètres → Mes appareils.
HUE_BRIDGE_IP=192.168.1.42

# Clé d'application générée via le bouton physique du Bridge.
# Dans les 30s qui suivent la pression, exécuter :
#   curl -k -X POST https://<bridge-ip>/api -d '{"devicetype":"loupgarou#serveur","generateclientkey":true}'
# Récupérer la valeur "username" du JSON renvoyé.
HUE_API_KEY=

# UUID v2 du groupe "Loup-Garou" (créer la pièce dans l'app Hue).
# Le récupérer via :
#   curl -k -H "hue-application-key: <clé>" https://<bridge-ip>/clip/v2/resource/grouped_light
# Choisir l'objet dont owner.rid correspond à la pièce "Loup-Garou".
HUE_GROUP_ID=

# Mettre à "true" pour logguer les commandes envoyées (utile à la mise au point).
LIGHTS_DEBUG=false
